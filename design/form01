  border-radius:var(--radius);
}

@media (prefers-reduced-motion: reduce){
  .flow-path{animation:none !important;}
}
</style>
</head>
<body>

<header class="site-nav">
  <div class="nav-inner">
    <div class="logo"><span class="dot"></span>AKUNTHA PROJECTS</div>
    <nav class="nav-links">
      <a href="#model">How RESCO Works</a>
      <a href="#eligibility">Eligibility</a>
      <a href="#industries">Industries</a>
      <a href="#faq">FAQ</a>
    </nav>
    <a class="nav-cta" href="#hero-form">Check Eligibility →</a>
  </div>
</header>

<!-- ============ HERO ============ -->
<section class="hero" id="hero">
  <div class="wrap hero-grid">
    <div>
      <div class="eyebrow">Commercial Solar Without Capital Investment</div>
      <h1>Reduce your business electricity costs without investing in a solar plant.</h1>
      <p class="hero-lead">Switch to commercial solar through the RESCO model. Akuntha Projects develops, installs, operates, and maintains the solar system, while eligible businesses purchase solar electricity under a long-term commercial agreement.</p>
      <div class="hero-clarify">No solar plant purchase is required. Commercial terms are structured according to the project, site, electricity consumption, and agreement period.</div>
      <div class="hero-cta-row">
        <a class="btn-primary" href="#hero-form">Check My Project Eligibility <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        <a class="link-anchor" href="#model">See How RESCO Works</a>
      </div>
      <div class="trust-points node-list">
        <li><span class="node-marker"></span>Zero upfront solar investment</li>
        <li><span class="node-marker"></span>Commercial &amp; industrial facilities</li>
        <li><span class="node-marker"></span>Engineering, EPC &amp; O&amp;M support</li>
        <li><span class="node-marker"></span>Rooftop &amp; ground-mounted options</li>
      </div>
    </div>

    <!-- FORM CARD -->
    <div class="form-card" id="hero-form">
      <div class="form-card-head">
        <h3>Get a Free RESCO Project Assessment</h3>
        <p>Answer a few questions about your facility and electricity use. Our engineering team will assess whether your site may be suitable for a RESCO project.</p>
      </div>
      <div class="progress-label"><span id="step-label">Step 1 of 4</span><span id="step-name">Facility</span></div>
      <div class="progress-track"><div class="progress-fill" id="progress-fill"></div></div>

      <form id="resco-form">
        <!-- STEP 1 -->
        <div class="f-step active" data-step="1">
          <h4>Tell Us About Your Facility</h4>
          <span class="field-label">What type of facility are you evaluating?</span>
          <div class="card-select" id="facility-select">
            <button type="button" class="opt-card" data-value="Manufacturing unit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 21V10l6 4v-4l6 4V6l6 4v11H3z"/></svg>Manufacturing unit</button>
            <button type="button" class="opt-card" data-value="Factory / industrial plant"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="10"/><path d="M7 11V7l4 3V6l4 3V4"/></svg>Factory / industrial plant</button>
            <button type="button" class="opt-card" data-value="Warehouse"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 10 12 4l9 6"/><rect x="4" y="10" width="16" height="10"/></svg>Warehouse</button>
            <button type="button" class="opt-card" data-value="Cold storage"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v20M4.9 4.9l14.2 14.2M19.1 4.9 4.9 19.1"/></svg>Cold storage</button>
            <button type="button" class="opt-card" data-value="Commercial building"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="3" width="14" height="18"/><path d="M9 7h1M14 7h1M9 11h1M14 11h1M9 15h1M14 15h1"/></svg>Commercial building</button>
            <button type="button" class="opt-card" data-value="Hospital"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="4" width="16" height="16"/><path d="M12 8v8M8 12h8"/></svg>Hospital</button>
            <button type="button" class="opt-card" data-value="Hotel"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="10" width="18" height="9"/><path d="M3 10V6h6v4M13 6h2v4"/></svg>Hotel</button>
            <button type="button" class="opt-card" data-value="Educational institution"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m2 9 10-5 10 5-10 5-10-5Zm4 2v6l6 3 6-3v-6"/></svg>Educational institution</button>
            <button type="button" class="opt-card" data-value="Retail / shopping complex"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 8h16l-1 12H5L4 8Zm4 0V6a4 4 0 0 1 8 0v2"/></svg>Retail / shopping complex</button>
            <button type="button" class="opt-card" data-value="Other"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/></svg>Other</button>
          </div>
          <div class="field-row three">
            <div><span class="field-label">State</span><input class="text-input" type="text" placeholder="e.g. Gujarat"></div>
            <div><span class="field-label">City</span><input class="text-input" type="text" placeholder="e.g. Ahmedabad"></div>
            <div><span class="field-label">Pincode</span><input class="text-input" type="text" inputmode="numeric" maxlength="6" placeholder="6-digit pincode"></div>
          </div>
          <div class="helper-text">Pincode helps us evaluate serviceability and route your enquiry to the right regional team.</div>
          <div class="f-actions"><span></span><button type="button" class="btn-continue" onclick="goStep(2)">Continue to Electricity Usage</button></div>
        </div>

        <!-- STEP 2 -->
        <div class="f-step" data-step="2">
          <h4>Tell Us About Your Electricity Consumption</h4>
          <span class="field-label">Approximate monthly electricity bill</span>
          <div class="pill-row" id="bill-select">
            <button type="button" class="pill" data-value="Below ₹50,000">Below ₹50,000</button>
            <button type="button" class="pill" data-value="₹50,000–₹1 lakh">₹50,000–₹1 lakh</button>
            <button type="button" class="pill" data-value="₹1–₹3 lakh">₹1–₹3 lakh</button>
            <button type="button" class="pill" data-value="₹3–₹5 lakh">₹3–₹5 lakh</button>
            <button type="button" class="pill" data-value="Above ₹5 lakh">Above ₹5 lakh</button>
            <button type="button" class="pill" data-value="Not sure">Not sure</button>
          </div>
          <span class="field-label">Approximate monthly electricity consumption <span style="color:var(--muted-2);text-transform:none;">(optional, kWh)</span></span>
          <input class="text-input" type="number" placeholder="e.g. 12000">
          <div class="helper-text">You can usually find this on your latest electricity bill.</div>
          <span class="field-label" style="margin-top:22px;">What is the property arrangement?</span>
          <div class="pill-row" id="own-select">
            <button type="button" class="pill" data-value="Owned">Owned</button>
            <button type="button" class="pill" data-value="Leased">Leased</button>
            <button type="button" class="pill" data-value="Shared ownership">Shared ownership</button>
            <button type="button" class="pill" data-value="Managed property">Managed property</button>
            <button type="button" class="pill" data-value="Not sure">Not sure</button>
          </div>
          <div class="f-actions"><button type="button" class="btn-back" onclick="goStep(1)">← Back</button><button type="button" class="btn-continue" onclick="goStep(3)">Continue to Site Details</button></div>
        </div>

        <!-- STEP 3 -->
        <div class="f-step" data-step="3">
          <h4>Tell Us About the Proposed Solar Site</h4>
          <span class="field-label">Where could solar potentially be installed?</span>
          <div class="pill-row" id="site-select">
            <button type="button" class="pill" data-value="Rooftop">Rooftop</button>
            <button type="button" class="pill" data-value="Open land">Open land</button>
            <button type="button" class="pill" data-value="Both">Both</button>
            <button type="button" class="pill" data-value="Not sure">Not sure</button>
          </div>
          <span class="field-label">Approximate available area <span style="color:var(--muted-2);text-transform:none;">(optional)</span></span>
          <div class="field-row">
            <input class="text-input" type="text" placeholder="Sq. ft. or sq. m.">
            <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--muted-2);"><input type="checkbox" id="area-unsure"> Not sure</label>
          </div>
          <span class="field-label" style="margin-top:22px;">What is your primary objective?</span>
          <div class="pill-row" id="obj-select">
            <button type="button" class="pill" data-value="Reduce electricity costs">Reduce electricity costs</button>
            <button type="button" class="pill" data-value="Avoid upfront capital investment">Avoid upfront capital investment</button>
            <button type="button" class="pill" data-value="Meet sustainability / ESG goals">Meet sustainability / ESG goals</button>
            <button type="button" class="pill" data-value="Support facility expansion">Support facility expansion</button>
            <button type="button" class="pill" data-value="Explore solar feasibility">Explore solar feasibility</button>
          </div>
          <div class="f-actions"><button type="button" class="btn-back" onclick="goStep(2)">← Back</button><button type="button" class="btn-continue" onclick="goStep(4)">Continue to Contact Details</button></div>
        </div>

        <!-- STEP 4 -->
        <div class="f-step" data-step="4">
          <h4>Where Should We Send Your Assessment?</h4>
          <div class="field-row">
            <div><span class="field-label">Company name</span><input class="text-input" type="text"></div>
            <div><span class="field-label">Contact person</span><input class="text-input" type="text"></div>
          </div>
          <div class="field-row">
            <div><span class="field-label">Mobile number</span><input class="text-input" type="tel"></div>
            <div><span class="field-label">Work email</span><input class="text-input" type="email"></div>
          </div>
          <span class="field-label">Preferred contact time</span>
          <div class="pill-row" id="time-select">
            <button type="button" class="pill" data-value="Morning">Morning</button>
            <button type="button" class="pill" data-value="Afternoon">Afternoon</button>
            <button type="button" class="pill" data-value="Evening">Evening</button>
            <button type="button" class="pill" data-value="No preference">No preference</button>
          </div>
          <span class="field-label">Electricity bill upload <span style="color:var(--muted-2);text-transform:none;">(optional)</span></span>
          <input class="text-input" type="file">
          <div class="consent-row">
            <input type="checkbox" id="consent-check">
            <label for="consent-check">By submitting this form, you agree to be contacted by Akuntha Projects via phone, SMS, WhatsApp, or email regarding your enquiry. Consent may be withdrawn at any time.</label>
          </div>
          <div class="f-actions"><button type="button" class="btn-back" onclick="goStep(3)">← Back</button><button type="submit" class="btn-continue">Request My Free RESCO Assessment</button></div>
          <div class="no-payment-note">No payment is required. Submission does not guarantee RESCO eligibility or project approval.</div>
        </div>

        <!-- SUCCESS -->
        <div class="f-success" id="f-success">
          <div class="mark"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg></div>
          <h3>Assessment request received</h3>
          <p>Our engineering team will review your facility details and get in touch during your preferred contact window.</p>
          <div class="ref">Reference ID: <span id="ref-id">AQ-2026-000000</span></div>
        </div>
      </form>
    </div>
  </div>
</section>

<!-- ============ COST PROBLEM ============ -->
<section class="cost-section section-pad" id="cost">
  <div class="wrap cost-grid">
    <div>
      <div class="eyebrow">The Cost of Grid Dependence</div>
      <h2>Rising electricity costs can limit business growth.</h2>
      <p class="body-text">Electricity is one of the largest operating expenses for many commercial and industrial businesses. Rising power tariffs can directly affect profitability, production costs, and long-term growth — often with little warning and no seat at the table when rates change.</p>
      <div class="cost-note">A RESCO project may convert unused space into a source of lower-cost onsite electricity — without requiring the business to purchase the solar plant upfront.</div>
    </div>
    <div class="data-cards">
      <div class="data-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M18.4 5.6l-2.8 2.8M8.4 15.6l-2.8 2.8"/><circle cx="12" cy="12" r="3"/></svg>
        <div><div class="t">High daytime electricity demand</div><div class="d">Production hours often overlap directly with peak solar generation windows.</div></div>
      </div>
      <div class="data-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 20V10l8-6 8 6v10"/><path d="M9 20v-6h6v6"/></svg>
        <div><div class="t">Significant monthly power bills</div><div class="d">Grid tariffs, fixed charges, and surcharges compound across a facility's operating year.</div></div>
      </div>
      <div class="data-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="9" width="18" height="10"/><path d="M7 9V5h10v4"/></svg>
        <div><div class="t">Underused rooftop or open land</div><div class="d">Available roof or land area often sits idle when it could be generating value.</div></div>
      </div>
    </div>
  </div>
</section>

<!-- ============ RESCO MODEL ============ -->
<section class="model-section section-pad" id="model">
  <div class="wrap">
    <div class="eyebrow">How the RESCO Model Works</div>
    <h2>Your facility connects to two sources — the grid, and an onsite solar array developed under a commercial agreement.</h2>
    <div class="flow-caption">RESCO Partner Invests <span class="arrow">→</span> Solar Plant Installed at Your Facility <span class="arrow">→</span> Your Business Uses Solar Electricity <span class="arrow">→</span> Plant Operated &amp; Maintained Professionally</div>

    <div class="diagram-wrap">
      <svg viewBox="0 0 900 230" xmlns="http://www.w3.org/2000/svg">
        <!-- Grid substation node -->
        <g transform="translate(40,30)">
          <rect x="0" y="0" width="120" height="66" fill="none" stroke="#7D82C2" stroke-width="1.2"/>
          <path d="M20 46 L30 20 L38 34 L46 14 L54 46" fill="none" stroke="#7D82C2" stroke-width="1.4"/>
          <text x="60" y="86" text-anchor="middle" class="diag-node-label">GRID SUBSTATION</text>
          <text x="60" y="99" text-anchor="middle" class="diag-node-sub">backup supply</text>
        </g>
        <!-- Solar array node -->
        <g transform="translate(40,150)">
          <rect x="0" y="0" width="120" height="50" fill="none" stroke="#F3B51B" stroke-width="1.2"/>
          <path d="M10 10 L50 10 L50 40 L10 40 Z M30 10 V40 M10 25 H50" stroke="#F3B51B" stroke-width="1" fill="none"/>
          <path d="M64 40 L64 15 L100 15" stroke="#F3B51B" stroke-width="1.2" fill="none"/>
          <text x="60" y="68" text-anchor="middle" class="diag-node-label">RESCO SOLAR ARRAY</text>
          <text x="60" y="81" text-anchor="middle" class="diag-node-sub">on your facility</text>
        </g>
        <!-- Facility node -->
        <g transform="translate(700,72)">
          <rect x="0" y="0" width="130" height="80" fill="none" stroke="#F2F3F8" stroke-width="1.2"/>
          <path d="M10 80 V60 H30 V80 M45 80 V60 H60 V80 M75 80 V60 H90 V80" stroke="#F2F3F8" stroke-width="1"/>
          <text x="65" y="100" text-anchor="middle" class="diag-node-label">YOUR FACILITY</text>
          <text x="65" y="113" text-anchor="middle" class="diag-node-sub">load centre</text>
        </g>
        <!-- Flow: grid -> facility -->
        <path class="flow-path" d="M160 63 C 420 63, 480 90, 700 100" fill="none" stroke="#7D82C2" stroke-width="2" stroke-dasharray="6 7">
          <animate attributeName="stroke-dashoffset" from="0" to="-26" dur="1.6s" repeatCount="indefinite"/>
        </path>
        <!-- Flow: solar -> facility -->
        <path class="flow-path" d="M160 190 C 420 190, 480 130, 700 112" fill="none" stroke="#F3B51B" stroke-width="2.4" stroke-dasharray="6 7">
          <animate attributeName="stroke-dashoffset" from="0" to="-26" dur="1.2s" repeatCount="indefinite"/>
        </path>
      </svg>
      <div class="flow-legend">
        <span><span class="legend-swatch" style="background:#F3B51B;"></span>Solar electricity (RESCO agreement)</span>
        <span><span class="legend-swatch" style="background:#7D82C2;"></span>Grid electricity (backup supply)</span>
      </div>
    </div>

    <div class="compare-grid">
      <div class="compare-col">
        <h4>Traditional solar purchase</h4>
        <ul>
          <li>Business funds the system</li>
          <li>Business owns the asset</li>
          <li>Capital investment required</li>
          <li>Maintenance responsibility depends on contract</li>
        </ul>
      </div>
      <div class="compare-col highlight">
        <h4>RESCO model</h4>
        <ul>
          <li>Project investment arranged by RESCO developer</li>
          <li>Solar system developed under a commercial agreement</li>
          <li>Business purchases generated solar electricity</li>
          <li>O&amp;M handled according to the agreement</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ============ BENEFITS ============ -->
<section class="section-pad" id="benefits">
  <div class="wrap">
    <div class="eyebrow">Key Benefits</div>
    <h2 style="font-size:30px;font-weight:600;max-width:600px;">Why businesses choose the RESCO model</h2>
    <div class="benefits-grid">
      <div class="benefit-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M8 12h8M12 8v8"/></svg>
        <h4>Zero Upfront Solar Investment</h4>
        <p>Preserve capital for production, expansion, staffing, equipment, or other business priorities.</p>
      </div>
      <div class="benefit-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 17l6-6 4 4 6-8"/><path d="M20 7h-4v4"/></svg>
        <h4>Potentially Lower Electricity Costs</h4>
        <p>Use onsite solar power to reduce the portion of electricity purchased from the grid.</p>
      </div>
      <div class="benefit-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.7 1.7 0 0 0 .34 1.87l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.7 1.7 0 0 0-1.87-.34 1.7 1.7 0 0 0-1 1.55V21a2 2 0 1 1-4 0v-.09A1.7 1.7 0 0 0 9 19.4a1.7 1.7 0 0 0-1.87.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.7 1.7 0 0 0 4.6 15a1.7 1.7 0 0 0-1.55-1H3a2 2 0 1 1 0-4h.09A1.7 1.7 0 0 0 4.6 9a1.7 1.7 0 0 0-.34-1.87l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.7 1.7 0 0 0 9 4.6a1.7 1.7 0 0 0 1-1.55V3a2 2 0 1 1 4 0v.09a1.7 1.7 0 0 0 1 1.55 1.7 1.7 0 0 0 1.87-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.7 1.7 0 0 0 19.4 9a1.7 1.7 0 0 0 1.55 1H21a2 2 0 1 1 0 4h-.09a1.7 1.7 0 0 0-1.55 1Z"/></svg>
        <h4>Professional Operations &amp; Maintenance</h4>
        <p>Monitoring, preventive maintenance, and performance support are managed throughout the agreed project term.</p>
      </div>
      <div class="benefit-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 17l6-11 4 7 3-4 5 8"/></svg>
        <h4>Engineering-Led Execution</h4>
        <p>Site assessment, system design, electrical integration, commissioning, and technical coordination are handled through one project team.</p>
      </div>
      <div class="benefit-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
        <h4>Long-Term Energy Planning</h4>
        <p>Create a more structured approach to electricity cost management and renewable energy adoption.</p>
      </div>
      <div class="benefit-card" style="display:flex;align-items:center;">
        <p class="benefit-caveat" style="margin-top:0;">Actual savings and terms depend on site assessment, consumption pattern, and the final commercial agreement — figures are indicative until then.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ ELIGIBILITY ============ -->
<section class="elig-section section-pad" id="eligibility">
  <div class="wrap">
    <div class="elig-head">
      <div class="eyebrow">Self-Assessment</div>
      <h2>Could your facility qualify for a RESCO project?</h2>
    </div>
    <div class="elig-checklist">
      <div class="elig-item"><span class="elig-check"></span>Your monthly electricity bill is substantial</div>
      <div class="elig-item"><span class="elig-check"></span>Most electricity is consumed during daytime hours</div>
      <div class="elig-item"><span class="elig-check"></span>Suitable rooftop or open land may be available</div>
      <div class="elig-item"><span class="elig-check"></span>You expect to operate from the facility long term</div>
      <div class="elig-item"><span class="elig-check"></span>You prefer to preserve capital instead of purchasing the solar system</div>
      <div class="elig-item"><span class="elig-check"></span>Your facility can support a long-term commercial energy agreement</div>
    </div>
    <div class="elig-note">RESCO suitability depends on energy consumption, site ownership or permission, structural feasibility, applicable regulations, credit evaluation, and commercial terms.</div>
    <div class="elig-cta-row"><a class="btn-primary" href="#hero-form">Check My Facility <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a></div>
  </div>
</section>

<!-- ============ PROCESS ============ -->
<section class="process-section section-pad" id="process">
  <div class="wrap">
    <div class="eyebrow">Sequence</div>
    <h2 style="font-size:30px;font-weight:600;">How the process works</h2>
    <div class="timeline">
      <div class="t-item"><div class="t-num">01</div><h4>Submit the Project Assessment</h4><p>Share your facility, electricity usage, and contact details.</p></div>
      <div class="t-item"><div class="t-num">02</div><h4>Initial Commercial Review</h4><p>Our team reviews consumption, location, and basic eligibility.</p></div>
      <div class="t-item"><div class="t-num">03</div><h4>Site &amp; Technical Assessment</h4><p>Engineers evaluate the roof or land, electrical system, shading, and grid requirements.</p></div>
