<script>
// ---------- multi-step form ----------
const totalSteps = 4;
const stepNames = {1:"Facility",2:"Electricity",3:"Site",4:"Contact"};
function goStep(n){
  document.querySelectorAll('.f-step').forEach(el=>{
    el.classList.toggle('active', parseInt(el.dataset.step)===n);
  });
  document.getElementById('step-label').textContent = `Step ${n} of ${totalSteps}`;
  document.getElementById('step-name').textContent = stepNames[n];
  document.getElementById('progress-fill').style.width = (n/totalSteps*100)+'%';
  document.getElementById('hero-form').scrollIntoView({block:'nearest'});
}

function wireSelectGroup(id, multi){
  const group = document.getElementById(id);
  if(!group) return;
  group.querySelectorAll('button').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      if(multi){
        btn.classList.toggle('selected');
      } else {
        group.querySelectorAll('button').forEach(b=>b.classList.remove('selected'));
        btn.classList.add('selected');
      }
    });
  });
}
['facility-select','bill-select','own-select','site-select','obj-select','time-select'].forEach(id=>wireSelectGroup(id,false));

document.getElementById('resco-form').addEventListener('submit', function(e){
  e.preventDefault();
  document.querySelectorAll('.f-step').forEach(el=>el.classList.remove('active'));
  document.getElementById('f-success').classList.add('active');
  const ref = 'AQ-2026-' + Math.floor(100000 + Math.random()*899999);
  document.getElementById('ref-id').textContent = ref;
});

// ---------- faq accordion ----------
document.querySelectorAll('.faq-item').forEach(item=>{
  const q = item.querySelector('.faq-q');
  const a = item.querySelector('.faq-a');
  q.addEventListener('click', ()=>{
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i=>{
      i.classList.remove('open');
      i.querySelector('.faq-a').style.maxHeight = null;
    });
    if(!isOpen){
      item.classList.add('open');
      a.style.maxHeight = a.scrollHeight + 'px';
    }
  });
});
</script>
