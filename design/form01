<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Akuntha Projects — Commercial Solar Under the RESCO Model</title>
<!-- Typography: this file uses the visitor's system font stack so it matches whatever
     heading/body font is already set globally in the site theme. When this markup is
     placed into Elementor, replace the --disp/--body values below with the theme's
     global Heading and Text font variables so the page inherits the site's type. -->
<style>
/* ============ TOKENS — Akuntha brand palette ============ */
:root{
  --ink:#1E2254;          /* darker navy — dark sections, hero overlays, strong contrast */
  --ink-2:#272C68;        /* akuntha primary navy — headings, buttons, progress, links, active states */
  --ink-3:#333A78;        /* elevated navy surface inside dark sections */
  --paper:#F6F7FB;        /* light background */
  --paper-2:#FFFFFF;
  --line:#E3E5EF;         /* border */
  --line-strong:rgba(39,44,104,0.22);
  --line-dark:rgba(246,247,251,0.14);
  --copper:#272C68;       /* mapped to akuntha primary navy — buttons / active selections / progress */
  --copper-bright:#43487C;/* akuntha secondary blue — hover states */
  --copper-dim:rgba(39,44,104,0.08);
  --steel:#43487C;        /* akuntha secondary blue — supporting graphics */
  --steel-bright:#6D72A6; /* lighter secondary blue for use on dark navy */
  --steel-dim:rgba(67,72,124,0.10);
  --yellow:#F3B51B;       /* solar yellow accent — used sparingly only */
  --text:#333642;
  --muted:#6C6F7D;
  --muted-2:#8A8D98;
  --on-ink:#F2F3F8;
  --on-ink-muted:#A9ACC4;
  --radius:3px;
  --disp:-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  --body:-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  --mono:-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}
*{box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  margin:0;
  font-family:var(--body);
  color:var(--text);
  background:var(--paper);
  -webkit-font-smoothing:antialiased;
  line-height:1.5;
}
img,svg{display:block;max-width:100%;}
a{color:inherit;}
h1,h2,h3,h4{font-family:var(--disp);margin:0;letter-spacing:-0.015em;font-weight:700;}
p{margin:0;}
button{font-family:var(--body);cursor:pointer;border-radius:var(--radius);}
input,select,textarea{border-radius:var(--radius);}
.wrap{max-width:1180px;margin:0 auto;padding:0 32px;}
.eyebrow{
  font-family:var(--mono);
  font-size:12px;
  font-weight:600;
  letter-spacing:0.14em;
  text-transform:uppercase;
  color:var(--yellow);
  display:flex;
  align-items:center;
  gap:10px;
  margin-bottom:14px;
}
.eyebrow::before{content:"";width:18px;height:1px;background:var(--yellow);display:block;}
section{position:relative;}
.section-pad{padding:96px 0;}
@media(max-width:860px){.section-pad{padding:64px 0;}.wrap{padding:0 20px;}}

/* node / breaker marker used as list bullet — reflects electrical disconnect symbol */
.node-list{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:14px;}
.node-list li{display:flex;align-items:flex-start;gap:14px;font-size:15.5px;color:var(--muted);}
.node-marker{
  flex:none;width:14px;height:14px;margin-top:3px;
  border:1.5px solid var(--yellow);
  position:relative;
  transform:rotate(45deg);
}
.node-marker::after{
  content:"";position:absolute;left:50%;top:-4px;bottom:-4px;width:1.5px;
  background:var(--yellow);transform:translateX(-50%);
}

/* ============ NAV ============ */
header.site-nav{
  position:sticky;top:0;z-index:100;
  background:rgba(236,238,231,0.92);
  backdrop-filter:blur(10px);
  border-bottom:1px solid var(--line);
}
.nav-inner{max-width:1180px;margin:0 auto;padding:18px 32px;display:flex;align-items:center;justify-content:space-between;}
.logo{font-family:var(--disp);font-weight:700;font-size:19px;letter-spacing:0.02em;display:flex;align-items:center;gap:8px;}
.logo .dot{width:8px;height:8px;background:var(--yellow);display:inline-block;}
.nav-links{display:flex;gap:32px;font-size:14px;color:var(--muted);}
.nav-links a{text-decoration:none;}
.nav-links a:hover{color:var(--ink);}
.nav-cta{
  font-family:var(--mono);font-size:13px;font-weight:500;
  background:var(--ink);color:var(--on-ink);
  padding:11px 20px;border:none;letter-spacing:0.02em;
  text-decoration:none;
}
@media(max-width:860px){.nav-links{display:none;}}

/* ============ HERO ============ */
.hero{
  background:var(--paper);
  background-image:
    linear-gradient(var(--line) 1px, transparent 1px),
    linear-gradient(90deg, var(--line) 1px, transparent 1px);
  background-size:56px 56px;
  padding:76px 0 90px;
}
.hero-grid{display:grid;grid-template-columns:1.05fr 1fr;gap:60px;align-items:start;}
@media(max-width:980px){.hero-grid{grid-template-columns:1fr;gap:44px;}}
.hero h1{font-size:44px;line-height:1.1;font-weight:600;max-width:600px;}
@media(max-width:560px){.hero h1{font-size:32px;}}
.hero-lead{margin-top:22px;font-size:17px;color:var(--muted);max-width:520px;line-height:1.6;}
.hero-clarify{
  margin-top:22px;padding:16px 18px;background:var(--paper-2);border-left:2px solid var(--steel);
  font-size:14px;color:var(--muted);max-width:520px;
}
.hero-cta-row{margin-top:32px;display:flex;align-items:center;gap:26px;flex-wrap:wrap;}
.btn-primary{
  background:var(--ink);color:var(--on-ink);border:none;
  padding:15px 26px;font-family:var(--mono);font-size:13.5px;letter-spacing:0.02em;
  display:inline-flex;align-items:center;gap:10px;text-decoration:none;
}
.btn-primary:hover{background:var(--copper-bright);}
.btn-primary svg{width:14px;height:14px;}
.link-anchor{font-size:14px;text-decoration:underline;text-underline-offset:4px;color:var(--muted);}
.trust-points{margin-top:40px;display:grid;grid-template-columns:1fr 1fr;gap:12px 24px;max-width:520px;}
@media(max-width:560px){.trust-points{grid-template-columns:1fr;}}

/* form card */
.form-card{
  background:var(--paper-2);
  border:1px solid var(--line-strong);
  padding:34px 32px 30px;
}
.form-card-head h3{font-size:21px;font-weight:600;}
.form-card-head p{margin-top:8px;font-size:13.5px;color:var(--muted-2);}
.progress-label{
  margin-top:24px;display:flex;justify-content:space-between;align-items:center;
  font-family:var(--mono);font-size:11.5px;letter-spacing:0.06em;color:var(--muted-2);text-transform:uppercase;
}
.progress-track{margin-top:8px;height:2px;background:var(--line);position:relative;}
.progress-fill{position:absolute;left:0;top:0;height:100%;background:var(--copper);width:25%;transition:width .35s ease;}

.f-step{display:none;margin-top:28px;}
.f-step.active{display:block;}
.f-step h4{font-size:15.5px;font-weight:600;margin-bottom:16px;}
.field-label{display:block;font-size:12.5px;color:var(--muted-2);margin:16px 0 8px;font-family:var(--mono);letter-spacing:0.03em;}
.field-label:first-child{margin-top:0;}
.text-input{
  width:100%;padding:12px 13px;border:1px solid var(--line-strong);background:var(--paper);
  font-family:var(--body);font-size:14.5px;color:var(--text);
}
.text-input:focus{outline:2px solid var(--copper);outline-offset:1px;}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.field-row.three{grid-template-columns:1fr 1fr 1fr;}
@media(max-width:520px){.field-row,.field-row.three{grid-template-columns:1fr;}}

.card-select{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
@media(max-width:520px){.card-select{grid-template-columns:1fr;}}
.opt-card{
  border:1px solid var(--line-strong);padding:12px 13px;font-size:13.5px;background:var(--paper);
  display:flex;align-items:center;gap:10px;text-align:left;
}
.opt-card svg{width:17px;height:17px;flex:none;color:var(--steel);}
.opt-card:hover{border-color:var(--copper-bright);}
.opt-card.selected{border-color:var(--copper);background:var(--copper-dim);}
.opt-card.selected svg{color:var(--copper);}

.pill-row{display:flex;flex-wrap:wrap;gap:9px;}
.pill{
  border:1px solid var(--line-strong);padding:9px 14px;font-size:13.5px;background:var(--paper);
}
.pill:hover{border-color:var(--copper-bright);}
.pill.selected{border-color:var(--copper);background:var(--copper-dim);color:var(--copper);}

.helper-text{margin-top:7px;font-size:12px;color:var(--muted-2);}

.consent-row{margin-top:20px;display:flex;gap:10px;align-items:flex-start;font-size:12.5px;color:var(--muted-2);}
.consent-row input{margin-top:2px;}

.f-actions{margin-top:26px;display:flex;justify-content:space-between;align-items:center;gap:14px;}
.btn-continue{
  background:var(--ink);color:var(--on-ink);border:none;flex:1;
  padding:14px 18px;font-family:var(--mono);font-size:13px;letter-spacing:0.02em;
}
.btn-continue:hover{background:var(--copper-bright);}
.btn-back{background:none;border:none;font-size:13px;color:var(--muted-2);text-decoration:underline;text-underline-offset:3px;padding:8px 0;}
.no-payment-note{margin-top:14px;font-size:11.5px;color:var(--muted-2);text-align:center;}

.f-success{display:none;text-align:center;padding:30px 6px 6px;}
.f-success.active{display:block;}
.f-success .mark{width:44px;height:44px;border:1.5px solid var(--copper);margin:0 auto 18px;display:flex;align-items:center;justify-content:center;transform:rotate(45deg);}
.f-success .mark svg{transform:rotate(-45deg);width:20px;height:20px;color:var(--copper);}
.f-success h3{font-size:19px;}
.f-success p{margin-top:10px;font-size:13.5px;color:var(--muted);max-width:340px;margin-left:auto;margin-right:auto;}
.f-success .ref{margin-top:16px;font-family:var(--mono);font-size:12.5px;color:var(--muted-2);}

/* ============ COST PROBLEM ============ */
.cost-section{background:var(--paper);border-top:1px solid var(--line);}
.cost-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start;}
@media(max-width:900px){.cost-grid{grid-template-columns:1fr;gap:36px;}}
.cost-grid h2{font-size:30px;font-weight:600;line-height:1.2;max-width:420px;}
.cost-grid .body-text{margin-top:18px;font-size:15.5px;color:var(--muted);max-width:440px;line-height:1.65;}
.data-cards{display:flex;flex-direction:column;gap:14px;}
.data-card{border:1px solid var(--line-strong);background:var(--paper-2);padding:20px 22px;display:flex;gap:16px;align-items:flex-start;}
.data-card svg{width:22px;height:22px;color:var(--steel);flex:none;margin-top:2px;}
.data-card .t{font-size:14.5px;font-weight:600;}
.data-card .d{margin-top:5px;font-size:13px;color:var(--muted-2);}
.cost-note{margin-top:22px;padding:18px 20px;border-left:2px solid var(--copper);background:var(--paper-2);font-size:14px;color:var(--muted);}

/* ============ RESCO MODEL / DIAGRAM ============ */
.model-section{background:var(--ink);color:var(--on-ink);}
.model-section .eyebrow{color:var(--yellow);}
.model-section h2{font-size:30px;font-weight:600;max-width:560px;color:var(--on-ink);}
.flow-caption{margin-top:10px;font-family:var(--mono);font-size:13px;color:var(--on-ink-muted);display:flex;flex-wrap:wrap;gap:8px;align-items:center;}
.flow-caption .arrow{color:var(--steel-bright);}

.diagram-wrap{margin-top:44px;border:1px solid var(--line-dark);padding:20px 10px 8px;overflow-x:auto;}
.diagram-wrap svg{min-width:640px;width:100%;}
.diag-node-label{font-family:var(--mono);font-size:11px;fill:var(--on-ink);}
.diag-node-sub{font-family:var(--mono);font-size:9.5px;fill:var(--on-ink-muted);}
.flow-legend{margin-top:14px;display:flex;gap:28px;font-family:var(--mono);font-size:11.5px;color:var(--on-ink-muted);padding:0 6px 10px;}
.flow-legend span{display:flex;align-items:center;gap:8px;}
.legend-swatch{width:16px;height:2px;display:inline-block;}

.compare-grid{margin-top:56px;display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--line-dark);border:1px solid var(--line-dark);}
@media(max-width:800px){.compare-grid{grid-template-columns:1fr;}}
.compare-col{background:var(--ink);padding:28px 26px;}
.compare-col.highlight{background:var(--ink-3);}
.compare-col h4{font-family:var(--mono);font-size:12.5px;letter-spacing:0.06em;text-transform:uppercase;color:var(--on-ink-muted);margin-bottom:18px;}
.compare-col.highlight h4{color:var(--yellow);}
.compare-col ul{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:13px;}
.compare-col li{font-size:14px;color:var(--on-ink);padding-left:16px;position:relative;line-height:1.5;}
.compare-col li::before{content:"";position:absolute;left:0;top:8px;width:6px;height:1.5px;background:var(--steel-bright);}
.compare-col.highlight li::before{background:var(--yellow);}

/* ============ BENEFITS ============ */
.benefits-grid{margin-top:44px;display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);}
@media(max-width:900px){.benefits-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:600px){.benefits-grid{grid-template-columns:1fr;}}
.benefit-card{background:var(--paper-2);padding:28px 24px;}
.benefit-card svg{width:24px;height:24px;color:var(--copper);}
.benefit-card h4{margin-top:16px;font-size:15.5px;font-weight:600;}
.benefit-card p{margin-top:9px;font-size:13.5px;color:var(--muted-2);line-height:1.55;}
.benefit-caveat{margin-top:20px;font-size:12.5px;color:var(--muted-2);font-style:italic;}

/* ============ ELIGIBILITY ============ */
.elig-section{background:var(--paper-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line);}
.elig-head{max-width:640px;}
.elig-head h2{font-size:30px;font-weight:600;}
.elig-checklist{margin-top:36px;display:grid;grid-template-columns:1fr 1fr;gap:14px 32px;}
@media(max-width:760px){.elig-checklist{grid-template-columns:1fr;}}
.elig-item{display:flex;gap:12px;align-items:flex-start;font-size:14.5px;padding:14px 0;border-bottom:1px solid var(--line);}
.elig-check{flex:none;width:16px;height:16px;border:1.5px solid var(--yellow);margin-top:2px;position:relative;}
.elig-check::after{content:"";position:absolute;left:3px;top:-1px;width:4px;height:8px;border-right:1.5px solid var(--yellow);border-bottom:1.5px solid var(--yellow);transform:rotate(40deg);}
.elig-note{margin-top:28px;padding:18px 20px;background:var(--steel-dim);border-left:2px solid var(--steel);font-size:13.5px;color:var(--muted);max-width:760px;}
.elig-cta-row{margin-top:30px;}

/* ============ PROCESS TIMELINE ============ */
.process-section{background:var(--paper);}
.timeline{margin-top:52px;position:relative;}
.timeline::before{content:"";position:absolute;left:27px;top:6px;bottom:6px;width:1px;background:var(--line-strong);}
@media(max-width:700px){.timeline::before{left:19px;}}
.t-item{position:relative;padding-left:74px;padding-bottom:38px;}
@media(max-width:700px){.t-item{padding-left:54px;padding-bottom:30px;}}
.t-item:last-child{padding-bottom:0;}
.t-num{
  position:absolute;left:0;top:0;width:56px;height:56px;border:1.5px solid var(--yellow);
  display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:16px;font-weight:700;color:var(--ink-2);
  background:var(--paper);z-index:1;
}
@media(max-width:700px){.t-num{width:40px;height:40px;font-size:13px;}}
.t-item h4{font-size:16.5px;font-weight:600;padding-top:14px;}
.t-item p{margin-top:8px;font-size:14px;color:var(--muted);max-width:600px;}

/* ============ WHY AKUNTHA ============ */
.why-section{background:var(--ink);color:var(--on-ink);}
.why-section .eyebrow{color:var(--yellow);}
.why-section h2{color:var(--on-ink);font-size:30px;font-weight:600;max-width:620px;}
.proof-strip{margin-top:36px;display:grid;grid-template-columns:repeat(4,1fr);border-top:1px solid var(--line-dark);border-bottom:1px solid var(--line-dark);}
@media(max-width:760px){.proof-strip{grid-template-columns:1fr 1fr;}}
.proof-item{padding:20px 18px;border-right:1px solid var(--line-dark);}
.proof-item:last-child{border-right:none;}
.proof-item .n{font-family:var(--mono);font-size:24px;font-weight:700;color:var(--yellow);}
.proof-item .l{margin-top:6px;font-size:12px;color:var(--on-ink-muted);}
.why-grid{margin-top:44px;display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line-dark);border:1px solid var(--line-dark);}
@media(max-width:900px){.why-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:560px){.why-grid{grid-template-columns:1fr;}}
.why-card{background:var(--ink);padding:26px 22px;}
.why-card svg{width:22px;height:22px;color:var(--steel-bright);}
.why-card h4{margin-top:15px;font-size:14.5px;font-weight:600;}
.why-card p{margin-top:9px;font-size:13px;color:var(--on-ink-muted);line-height:1.55;}

/* ============ INDUSTRIES ============ */
.industries-grid{margin-top:44px;display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line);border:1px solid var(--line);}
@media(max-width:900px){.industries-grid{grid-template-columns:repeat(2,1fr);}}
.ind-card{background:var(--paper-2);padding:22px 20px;min-height:150px;display:flex;flex-direction:column;justify-content:space-between;}
.ind-card svg{width:22px;height:22px;color:var(--copper);}
.ind-card .t{margin-top:14px;font-size:14px;font-weight:600;}
.ind-card .d{margin-top:6px;font-size:12px;color:var(--muted-2);line-height:1.5;}

/* ============ CTA BANNER ============ */
.cta-banner{background:var(--ink-2);color:var(--on-ink);border-top:3px solid var(--yellow);}
.cta-banner-inner{display:flex;justify-content:space-between;align-items:center;gap:30px;flex-wrap:wrap;}
.cta-banner h2{font-size:26px;font-weight:700;max-width:520px;color:var(--on-ink);}
.cta-banner p{margin-top:10px;font-size:14.5px;color:var(--on-ink-muted);max-width:480px;}
.cta-banner .btn-primary{background:var(--yellow);color:var(--ink-2);}
.cta-banner .btn-primary:hover{background:#ffc94d;}
.cta-note{margin-top:14px;font-family:var(--mono);font-size:12px;color:var(--on-ink-muted);}

/* ============ FAQ ============ */
.faq-section{background:var(--paper);}
.faq-list{margin-top:40px;max-width:820px;}
.faq-item{border-bottom:1px solid var(--line-strong);}
.faq-q{width:100%;background:none;border:none;text-align:left;padding:20px 0;display:flex;justify-content:space-between;align-items:center;gap:20px;font-size:15.5px;font-weight:500;color:var(--text);}
.faq-q .plus{flex:none;width:16px;height:16px;position:relative;}
.faq-q .plus::before,.faq-q .plus::after{content:"";position:absolute;background:var(--copper);}
.faq-q .plus::before{left:0;right:0;top:50%;height:1.5px;transform:translateY(-50%);}
.faq-q .plus::after{top:0;bottom:0;left:50%;width:1.5px;transform:translateX(-50%);transition:transform .2s ease;}
.faq-item.open .faq-q .plus::after{transform:translateX(-50%) rotate(90deg);opacity:0;}
.faq-a{max-height:0;overflow:hidden;transition:max-height .28s ease;}
.faq-a-inner{padding-bottom:20px;font-size:14.5px;color:var(--muted);max-width:680px;line-height:1.6;}

/* ============ FINAL CTA ============ */
.final-section{background:var(--ink);color:var(--on-ink);text-align:center;}
.final-section h2{font-size:32px;font-weight:600;color:var(--on-ink);max-width:640px;margin:0 auto;}
.final-section p{margin-top:16px;font-size:15.5px;color:var(--on-ink-muted);max-width:560px;margin-left:auto;margin-right:auto;}
.final-actions{margin-top:32px;display:flex;justify-content:center;align-items:center;gap:26px;flex-wrap:wrap;}
.final-section .btn-primary{background:var(--yellow);color:var(--ink-2);}
.final-section .btn-primary:hover{background:#ffc94d;}

/* ============ FOOTER ============ */
footer{background:var(--ink);border-top:1px solid var(--line-dark);padding:40px 0 30px;color:var(--on-ink-muted);}
.footer-top{display:flex;justify-content:space-between;gap:30px;flex-wrap:wrap;padding-bottom:26px;border-bottom:1px solid var(--line-dark);}
.footer-top .logo{color:var(--on-ink);}
.footer-links{display:flex;gap:26px;font-size:13px;flex-wrap:wrap;}
.disclaimer{margin-top:24px;font-size:12px;line-height:1.7;max-width:900px;color:var(--on-ink-muted);}
.disclaimer b{color:var(--on-ink);font-weight:600;}
.copyright{margin-top:18px;font-family:var(--mono);font-size:11.5px;}

